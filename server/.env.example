# ───────────────────────────────────────────────
#  Visual Physics — настройки сервера
#  Скопируйте этот файл в  .env  и заполните значения.
# ───────────────────────────────────────────────

# ── Telegram: уведомления о новых заявках ──
# 1) Откройте @BotFather в Telegram → /newbot → получите токен
TELEGRAM_BOT_TOKEN=
# 2) Узнайте chat_id: напишите боту сообщение, затем  npm run chat-id
#    Это ЧИСЛОВОЙ id получателя (напр. 123456789), а НЕ имя бота.
#    Можно указать несколько получателей через запятую: 12345,67890
TELEGRAM_CHAT_ID=

# ── Админка заявок (страница /admin) ──
# Придумайте свой секретный пароль-токен (любая строка)
ADMIN_TOKEN=

# ── ИИ-чат (необязательно) ──
# Пусто = бот работает в режиме FAQ без ключа (бесплатно).
# Основной вариант: OpenAI. Не добавляйте ключ в HTML, JavaScript браузера или git.
AI_PROVIDER=gemini
GEMINI_API_KEY=
# Можно переопределить модель Gemini при необходимости:
# GEMINI_MODEL=gemini-2.5-flash

# Совместимый вариант: OpenAI.
# AI_PROVIDER=openai
OPENAI_API_KEY=
# Можно переопределить модель при необходимости:
# OPENAI_MODEL=gpt-4.1-mini

# Совместимый вариант: Anthropic / Claude.
ANTHROPIC_API_KEY=
# CHAT_MODEL=claude-haiku-4-5-20251001

# ── Прочее ──
# Порт сервера (по умолчанию 3000)
# PORT=3000
